# Appwrite Configuration
# These are the public variables exposed to the frontend browser
NEXT_PUBLIC_APPWRITE_ENDPOINT="https://cloud.appwrite.io/v1"
NEXT_PUBLIC_APPWRITE_PROJECT_ID="your-project-id"

# This is the secret API key for server-side operations (Admin portal, API server)
# DO NOT expose this to the frontend!
APPWRITE_API_KEY="your-secret-api-key"
